<div
    id="{{containerid}}"
    class="block-portalmessage {{typeclass}}"
    role="{{ariarole}}"
    data-region="portal-message"
    data-message-version="{{messageversion}}"
>
    <div class="block-portalmessage__text">{{{message}}}</div>
    <button type="button" class="btn btn-link p-0 block-portalmessage__dismiss" data-action="dismiss">
        {{dismisslabel}}
    </button>
</div>
